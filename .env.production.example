# Career Forge — VPS production (copy to /home/ubuntu/soft-push/.env)

# Postgres
POSTGRES_USER=careerforge
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=careerforge

# Bind ports on the VPS host (Career Forge stays on localhost)
FRONTEND_HOST_PORT=13000
BACKEND_HOST_PORT=18000

# Domains served by your existing host nginx
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
CERTBOT_EMAIL=you@example.com

# Backend CORS (must include the browser origin)
# Example: https://app.example.com
CORS_ORIGINS=https://app.example.com

# URLs baked into the frontend at image build time
NEXT_PUBLIC_BACKEND_URL=https://api.example.com
NEXT_PUBLIC_API_URL=https://api.example.com

# Backend behavior
ENV=production
DEBUG=false
# Catalog seed runs on every backend start (idempotent). Demo Ana only when true.
SEED_DEMO_ANA=false
# Skill catalog file (compose mounts ./data -> /data; must exist on VPS)
ROADMAP_JSON_PATH=/data/roadmap.json
# Persistence (auto=postgres when ENV=production)
DIAGNOSIS_SESSION_STORE=postgres
GRAPH_RUN_STORE=postgres
DIAGNOSIS_INTERVIEW_MODEL=gpt-4.1-nano

# AI providers (required for the diagnosis interview/forge in production)
OPENAI_API_KEY=
FORGE_SEARCH_MODEL=gpt-5.4
FORGE_EVALUATOR_MODEL=gpt-5.4-mini
FORGE_STREAM_DELAY_SEC=1.5
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=career-forge

# GHCR images (must match tags pushed by .github/workflows/deploy.yml)
GHCR_IMAGE_NAMESPACE=ghcr.io/pedroalano
IMAGE_TAG=latest
