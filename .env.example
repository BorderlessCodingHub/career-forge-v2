# Career Forge — local dev (copy to .env)

# Postgres (HAC-6 defaults)
POSTGRES_USER=careerforge
POSTGRES_PASSWORD=careerforge
POSTGRES_DB=careerforge

# Backend
BACKEND_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://careerforge:careerforge@localhost:5432/careerforge
# Must include every browser origin (match WEB_HOST_PORT)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3300,http://127.0.0.1:3300
ENV=local
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_USER_ID=demo-ana
API_INTERNAL_URL=http://localhost:8000
WEB_HOST_PORT=3300

# Demo seed (docker backend startup)
SEED_DEMO_ANA=true

# AI — required for diagnosis interview (OpenAI)
OPENAI_API_KEY=
# Fast nano model for Judge + Interviewer (override: gpt-5-nano, gpt-5.4-nano, etc.)
DIAGNOSIS_INTERVIEW_MODEL=gpt-4.1-nano
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=career-forge

# Linear MCP (Cursor Cloud / Mobile Bearer auth — set in Cloud secrets; optional locally)
# HACKATON_LINEAR_API_KEY=
